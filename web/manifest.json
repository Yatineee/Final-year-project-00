{
    "name": "Arete",
    "description": "Tackle doomscrolling. Become your potential.",
    "version": "1.0",
    "manifest_version": 3,
    "icons": {
        "16": "./logo.png",
        "32": "./logo.png",
        "48": "./logo.png",
        "128": "./logo.png"
    },
    "action": {
        "default_popup": "dashboard.html",
        "default_icon": "./logo.png"
    },
    "background": {
        "service_worker": "background.bundle.js"
    },
    "content_scripts": [
        {
            "js": [
                "content.bundle.js"
            ],
            "matches": [
                "https://www.instagram.com/*",
                "https://www.facebook.com/*",
                "https://www.x.com/*",
                "https://www.reddit.com/*",
                "https://www.tiktok.com/*",
                "https://www.youtube.com/*",
                "https://www.snapchat.com/*"
            ]
        }
    ]
}